{
  "name": "open-higgsfield-ai",
  "description": "Open-source alternative to Higgsfield AI — AI image generation and cinema studio with 20+ models",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "playwright test --project=performance",
    "test:accessibility": "playwright test --project=accessibility",
    "test:modules": "playwright test --project=modules",
    "test:apps": "playwright test --project=apps",
    "test:lint": "eslint src tests --ext .js,.ts,.jsx,.tsx",
    "test:typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build:packages": "npm run build --workspaces --if-present",
    "dev:packages": "npm run dev --workspaces --if-present",
    "performance:analyze": "node scripts/performance-analysis.js",
    "performance:budget": "node -e \"import('./src/lib/performance-budget.js').then(m => m.performanceBudget.runCIChecks())\"",
    "dev:cinegen": "cd modules/CineGen && npm run dev",
    "dev:ltx-desktop": "cd modules/LTX-Desktop && npm run dev",
    "dev:director": "cd apps/director && npm run dev",
    "dev:vimax": "cd apps/vimax && npm run dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.24",
    "canvas": "^3.2.3",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.6",
    "puppeteer": "^24.37.2",
    "tailwindcss": "^4.1.18",
    "terser": "^5.27.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@higgsfield/layout": "file:packages/layout",
    "@higgsfield/navigation": "file:packages/navigation",
    "@higgsfield/tokens": "file:packages/tokens",
    "@supabase/supabase-js": "^2.99.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "dompurify": "^3.3.3",
    "interactjs": "^1.10.27",
    "lucide-react": "^1.8.0",
    "mobx-react-lite": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
